# PostgreSQL 직접 연결 (SQLAlchemy용)
# Supabase 대시보드 → Project Settings → Database → Connection string (URI)에서 복사
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Supabase (Phase 3: Storage 이미지 업로드 전용)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# JWT
JWT_SECRET=[임의의 시크릿 키]
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
